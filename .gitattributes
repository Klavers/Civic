*.exr                   binary
*.fbx                   binary
*.gif                   binary
*.hdr                   binary
*.jpeg                  binary
*.jpg                   binary
*.mov                   binary
*.mp3                   binary
*.mp4                   binary
*.obj                   binary
*.ogg                   binary
*.otf                   binary
*.pdf                   binary
*.png                   binary
*.psd                   binary
*.so                    binary
*.tga                   binary
*.tif                   binary
*.tiff                  binary
*.ttf                   binary
*.unitypackage          binary
*.wav                   binary
